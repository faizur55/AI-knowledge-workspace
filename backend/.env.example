APP_NAME=Production RAG Chatbot
APP_VERSION=1.0.0
DEBUG=True

DATABASE_URL=sqlite:///./rag_chatbot.db

# --- LLM provider ---
# groq: fast (1-3s typical), free tier, open-weight models, but the
#       document text/questions leave your server for this API call.
# ollama: fully local/private, needs real CPU/RAM/GPU or it's very slow.
LLM_PROVIDER=groq

# Free key: https://console.groq.com/keys (no credit card required)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# Only used if LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llama3.2-vision

SECRET_KEY=
REFRESH_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MAX_UPLOAD_MB=25
RATE_LIMIT_PER_MINUTE=30

# --- Account lockout ---
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# --- Google Sign-In (optional -- leave blank to disable the button) ---
# Free OAuth Client ID: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# --- Password reset email (optional -- without this, reset links are
# logged to the server console instead of emailed) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
FRONTEND_URL=http://localhost:5173

# --- First admin account (optional, one-time bootstrap) ---
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
