# Leave unset for local `npm run dev` against http://127.0.0.1:8000 directly.
# Set to /api to test the same nginx-proxied path production uses (see
# vite.config.js's dev server proxy).
VITE_API_BASE_URL=

# Optional -- same Client ID as backend/.env's GOOGLE_CLIENT_ID. Leave
# blank to hide the "Sign in with Google" button entirely.
VITE_GOOGLE_CLIENT_ID=
